#!/bin/bash

image=reg.nemui.org/cclaude/cclaude

volumes=()

for t in /etc/passwd:ro /etc/group:ro \
	~/.claude.json ~/.claude ~/.local/share/claude ~/.local/bin:ro ~/.agents \
	~/.gitconfig:ro ~/.aws:ro ~/.config/ccstatusline:ro ~/.config/gh:ro \
	~/.nodenv ~/.rustup ~/.rbenv ~/.bun ~/.cargo ~/.npm ~/.inputrc:ro \
	/run/user/$(id -u)/bus:ro ${SSH_AUTH_SOCK} ~/.ssh/known_hosts:ro ${TMUX} \
	; do
  path="${t%%:*}"
  if [ -z "$path" ]; then
    continue;
  elif [ -L "$path" ]; then
    volumes+=(-v "$(readlink -n "$path"):$t")
  elif [ -e "$path" ]; then
    volumes+=(-v "$path:$t")
  fi
done

# Resolve this pane's KWin window on the host (the container can't reach KWin)
# and inject it so win-record.sh stores it without re-resolving inside the container.
winenv=()
winid="$("$HOME/.claude/hooks/kwin.sh" resolve 2>/dev/null)"
if [ -n "$winid" ]; then
  winenv=(-e CLAUDE_WIN_ID="$winid")
fi

exec docker run -w "$PWD" -v "$PWD:$PWD" \
  -e PATH -e COLORTERM -e TERM -e DBUS_SESSION_BUS_ADDRESS -e USER -e HOME -e SSH_AUTH_SOCK \
  -e TERM_PROGRAM -e WEZTERM_PANE -e WEZTERM_UNIX_SOCKET -e TMUX -e TMUX_PANE \
  -e KONSOLE_DBUS_ACTIVATION_COOKIE -e KONSOLE_DBUS_SESSION -e KONSOLE_DBUS_WINDOW \
  "${winenv[@]}" \
  --rm -it "${volumes[@]}" \
  "$image" "${@}"

