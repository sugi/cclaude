#!/bin/bash

cmd=claude

case "$1" in
  bash|/bin/bash|bunx|npx)
    cmd="$1"
    shift
    ;;
esac


if [ '!' -z "$USER" ]; then
  export SHELL=/bin/bash
  # Docker creates missing bind-mount parents as root; give them back to the
  # user. -xdev stays on the container overlay and the mountpoint check keeps
  # host-owned trees untouched.
  find "$HOME" -xdev -type d -uid 0 ! -exec mountpoint -q {} \; -exec chown "$USER" {} \;
  if [ -e "$HOME/.ssh" ]; then
    chmod 700 "$HOME/.ssh"
  fi
  exec sudo -E -u "$USER" env "PATH=$PATH" "$cmd" "${@}"
else
  exec "$cmd" "${@}"
fi
