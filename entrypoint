#!/bin/bash

cmd=claude

case "$1" in
  bash|/bin/bash|bunx|npx)
    cmd="$1"
    shift
    ;;
esac


if [ '!' -z "$USER" ]; then
  export SHELL=/bin/bash
  chown $USER $HOME
  if [ -e $HOME/.ssh ]; then
    chown $USER $HOME/.ssh
    chmod 700 $HOME/.ssh
  fi
  exec sudo -E -u "$USER" env "PATH=$PATH" "$cmd" "${@}"
else
  exec "$cmd" "${@}"
fi
